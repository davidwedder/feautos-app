import express, { Request, Response, NextFunction } from "express";
import { createServer as createViteServer } from "vite";
import path from "path";
import fs from "fs";
import Database from "better-sqlite3";
import multer from "multer";
import session from "express-session";
import dotenv from "dotenv";

dotenv.config();

const app = express();
const PORT = parseInt(process.env.PORT || "3000", 10);

// Configuração para confiar no proxy (essencial para cookies seguros em iframes)
app.set("trust proxy", 1);

// Database Setup
// Use a configurable path for SQLite file (env: SQLITE_FILE). Default to ./data/fe_autos.db
const dataDir = path.resolve(process.cwd(), "data");
if (!fs.existsSync(dataDir)) fs.mkdirSync(dataDir, { recursive: true });
const DB_PATH = process.env.SQLITE_FILE ? path.resolve(process.cwd(), process.env.SQLITE_FILE) : path.join(dataDir, "fe_autos.db");
console.log(`[DB] using SQLite file: ${DB_PATH}`);
const db = new Database(DB_PATH);

// Improve concurrency: enable WAL mode and set a busy timeout to reduce SQLITE_BUSY errors
try {
  db.pragma("journal_mode = WAL");
  db.pragma("busy_timeout = 5000"); // 5000 ms
} catch (e) {
  console.warn("Could not set SQLite PRAGMAs:", e);
}
db.exec(`
  CREATE TABLE IF NOT EXISTS cars (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    brand TEXT NOT NULL,
    model TEXT NOT NULL,
    year INTEGER NOT NULL,
    price REAL NOT NULL,
    mileage INTEGER NOT NULL,
    fuel TEXT NOT NULL,
    transmission TEXT NOT NULL,
    status TEXT DEFAULT 'available', -- available, featured, sold
    images TEXT NOT NULL, -- JSON array of image paths
    description TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
  );

  -- Configurações da loja (apenas um registro)
  CREATE TABLE IF NOT EXISTS store_settings (
    id INTEGER PRIMARY KEY CHECK (id = 1),
    phone TEXT NOT NULL,
    email TEXT NOT NULL,
    address TEXT NOT NULL,
    hours_week TEXT NOT NULL,
    hours_saturday TEXT NOT NULL,
    hours_sunday TEXT NOT NULL,
    instagram_url TEXT,
    facebook_url TEXT
  );

  INSERT INTO store_settings (
    id, phone, email, address,
    hours_week, hours_saturday, hours_sunday,
    instagram_url, facebook_url
  )
  SELECT
    1,
    '(11) 99999-9999',
    'contato@feautos.com.br',
    'Av. Principal, 1000 - Centro\nSão Paulo - SP',
    '09h - 18h',
    '09h - 14h',
    'Fechado',
    '#',
    '#'
  WHERE NOT EXISTS (SELECT 1 FROM store_settings WHERE id = 1);
`);

// Garante colunas de imagens em qualquer base (nova ou existente)
try {
  db.prepare("ALTER TABLE store_settings ADD COLUMN about_image_url TEXT").run();
} catch (e) {
  // Se a coluna já existe, ignoramos o erro
}
try {
  db.prepare("ALTER TABLE store_settings ADD COLUMN hero_image_url TEXT").run();
} catch (e) {
  // Se a coluna já existe, ignoramos o erro
}

// Define valores padrão para imagens se estiverem nulos
db.prepare(
  `
  UPDATE store_settings
  SET 
    about_image_url = COALESCE(
      about_image_url,
      'https://images.unsplash.com/photo-1552519507-da3b142c6e3d?auto=format&fit=crop&q=80&w=1000'
    ),
    hero_image_url = COALESCE(
      hero_image_url,
      COALESCE(
        about_image_url,
        'https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1920'
      )
    )
  WHERE id = 1
`
).run();

// Multer Setup for Image Uploads
const uploadDir = path.resolve("public/uploads");
if (!fs.existsSync(uploadDir)) {
  fs.mkdirSync(uploadDir, { recursive: true });
}

const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    cb(null, uploadDir);
  },
  filename: (req, file, cb) => {
    const uniqueSuffix = Date.now() + "-" + Math.round(Math.random() * 1e9);
    cb(null, uniqueSuffix + path.extname(file.originalname));
  },
});
const upload = multer({ 
  storage,
  limits: { fileSize: 5 * 1024 * 1024 } // Limite de 5MB por foto
});

// Body parsers & Session Setup
app.use(express.json({ limit: '10mb' }));
app.use(express.urlencoded({ extended: true, limit: '10mb' }));

app.use((req, res, next) => {
  console.log(`[${new Date().toISOString()}] ${req.method} ${req.url} - IP: ${req.ip}`);
  next();
});

app.use(
  session({
    secret: process.env.SESSION_SECRET || "fe-autos-secret",
    resave: true,
    saveUninitialized: true,
    name: "feautos.sid",
    proxy: true, // Fundamental para ambientes com proxy (Cloud Run/AI Studio)
    cookie: {
      // Em produção (HTTPS) usamos cookie seguro; em desenvolvimento (HTTP localhost) não
      secure: process.env.NODE_ENV === "production",
      sameSite: process.env.NODE_ENV === "production" ? "none" : "lax",
      httpOnly: true,
      maxAge: 7 * 24 * 60 * 60 * 1000 // 1 semana
    }
  })
);

// Auth Middleware usando sessão local
const isAdmin = (req: express.Request, res: express.Response, next: express.NextFunction) => {
  const user = (req.session as any)?.user;
  console.log(
    `[Auth Check] Path: ${req.url}, User: ${user ? user.email || "Sim" : "Não"}`
  );

  if (user) {
    return next();
  }
  res.status(401).json({ error: "Sessão expirada ou não autorizado. Por favor, faça login novamente." });
};

// API Routes
app.use("/uploads", express.static(path.resolve("public/uploads")));

// --- Autenticação local (usuário/senha simples) ---
const ADMIN_EMAIL = process.env.ADMIN_EMAIL || "admin@feautos.local";
const ADMIN_PASSWORD = process.env.ADMIN_PASSWORD || "admin123";

app.post("/api/auth/login", (req, res) => {
  const { email, password } = req.body || {};

  if (!email || !password) {
    return res.status(400).json({ error: "E-mail e senha são obrigatórios." });
  }

  if (email === ADMIN_EMAIL && password === ADMIN_PASSWORD) {
    (req.session as any).user = { email };
    return res.json({ success: true, user: { email } });
  }

  return res.status(401).json({ error: "Credenciais inválidas." });
});

// Store settings API (protegida)
app.get("/api/store-settings", (req, res) => {
  try {
    const row = db.prepare("SELECT * FROM store_settings WHERE id = 1").get();
    res.json(row);
  } catch (err: any) {
    console.error("Erro ao carregar configurações da loja:", err);
    res.status(500).json({ error: "Erro ao carregar configurações" });
  }
});

app.post("/api/store-settings", isAdmin, (req, res) => {
  try {
    const {
      phone,
      email,
      address,
      hours_week,
      hours_saturday,
      hours_sunday,
      instagram_url,
      facebook_url,
      hero_image_url,
      about_image_url,
      new_hero_image,
      new_about_image,
    } = req.body;

    let finalHeroImageUrl = hero_image_url;
    let finalAboutImageUrl = about_image_url;

    // Processa nova imagem do HERO, se enviada
    if (
      new_hero_image &&
      typeof new_hero_image === "string" &&
      new_hero_image.includes(";base64,")
    ) {
      try {
        const parts = new_hero_image.split(";base64,");
        const mime = parts[0].split(":")[1] || "image/jpeg";
        const ext = mime.split("/")[1] || "jpg";
        const data = parts[1];
        const buffer = Buffer.from(data, "base64");

        const filename = `hero-${Date.now()}.${ext}`;
        const filepath = path.join(uploadDir, filename);
        fs.writeFileSync(filepath, buffer);
        finalHeroImageUrl = `/uploads/${filename}`;
      } catch (e) {
        console.error("Erro ao processar nova imagem do HERO:", e);
      }
    }

    // Processa nova imagem da seção Sobre Nós, se enviada
    if (
      new_about_image &&
      typeof new_about_image === "string" &&
      new_about_image.includes(";base64,")
    ) {
      try {
        const parts = new_about_image.split(";base64,");
        const mime = parts[0].split(":")[1] || "image/jpeg";
        const ext = mime.split("/")[1] || "jpg";
        const data = parts[1];
        const buffer = Buffer.from(data, "base64");

        const filename = `about-${Date.now()}.${ext}`;
        const filepath = path.join(uploadDir, filename);
        fs.writeFileSync(filepath, buffer);
        finalAboutImageUrl = `/uploads/${filename}`;
      } catch (e) {
        console.error("Erro ao processar nova imagem da seção Sobre Nós:", e);
      }
    }

    db.prepare(
      `
      UPDATE store_settings
      SET phone = ?, email = ?, address = ?,
          hours_week = ?, hours_saturday = ?, hours_sunday = ?,
          instagram_url = ?, facebook_url = ?, hero_image_url = ?, about_image_url = ?
      WHERE id = 1
    `
    ).run(
      phone,
      email,
      address,
      hours_week,
      hours_saturday,
      hours_sunday,
      instagram_url,
      facebook_url,
      finalHeroImageUrl,
      finalAboutImageUrl
    );

    res.json({ success: true });
  } catch (err: any) {
    console.error("Erro ao salvar configurações da loja:", err);
    res.status(500).json({ error: "Erro ao salvar configurações" });
  }
});

app.get("/api/cars", (req, res) => {
  try {
    const cars = db.prepare("SELECT * FROM cars ORDER BY created_at DESC").all();
    res.json(cars.map((car: any) => ({ ...car, images: JSON.parse(car.images) })));
  } catch (error) {
    console.error("Erro ao buscar carros:", error);
    res.status(500).json({ error: "Erro interno ao buscar carros" });
  }
});

// Helper para limpar formatação de números (ex: "50.000,00" -> 50000.00)
const cleanNumber = (val: any): number => {
  if (!val) return 0;
  if (typeof val === "number") return val;
  // Remove pontos de milhar e troca vírgula por ponto
  const cleaned = val.toString().replace(/\./g, "").replace(",", ".");
  return parseFloat(cleaned) || 0;
};

app.post("/api/cars", (req, res) => {
  try {
    console.log(">>> [POST /api/cars] Recebendo JSON...");
    const { brand, model, year, price, mileage, fuel, transmission, status, description, newImages } = req.body;

    if (!brand || !model) {
      return res.status(400).json({ error: "Marca e Modelo são obrigatórios" });
    }

    const yearNum = parseInt(year) || new Date().getFullYear();
    const priceNum = cleanNumber(price);
    const mileageNum = cleanNumber(mileage);
    
    // Processar imagens Base64
    const savedImages: string[] = [];
    if (newImages && Array.isArray(newImages)) {
      newImages.forEach((base64: string, index: number) => {
        if (!base64.includes(";base64,")) return;
        
        const parts = base64.split(";base64,");
        const mime = parts[0].split(":")[1];
        const ext = mime.split("/")[1] || "png";
        const data = parts[1];
        const buffer = Buffer.from(data, "base64");
        
        const filename = `img-${Date.now()}-${index}.${ext}`;
        const filepath = path.join(uploadDir, filename);
        fs.writeFileSync(filepath, buffer);
        savedImages.push(`/uploads/${filename}`);
      });
    }

    const stmt = db.prepare(`
      INSERT INTO cars (brand, model, year, price, mileage, fuel, transmission, status, images, description)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `);
    
    const result = stmt.run(
      brand, 
      model, 
      yearNum, 
      priceNum, 
      mileageNum, 
      fuel || 'Flex', 
      transmission || 'Automático', 
      status || 'available', 
      JSON.stringify(savedImages), 
      description || ''
    );
    
    console.log(">>> [Success] Veículo cadastrado via JSON!");
    return res.status(200).json({ id: result.lastInsertRowid, success: true });
  } catch (error: any) {
    console.error(">>> [Error]:", error);
    return res.status(500).json({ error: "Erro no servidor: " + error.message });
  }
});

app.put("/api/cars/:id", isAdmin, (req, res) => {
  upload.array("images")(req, res, (err) => {
    if (err) {
      console.error("Erro no Multer (Update):", err);
      return res.status(400).json({ error: "Erro nas imagens: " + err.message });
    }

    try {
      console.log("Atualizando carro ID:", req.params.id);
      const { brand, model, year, price, mileage, fuel, transmission, status, description, existingImages } = req.body;
      
      const yearNum = parseInt(year) || new Date().getFullYear();
      const priceNum = cleanNumber(price);
      const mileageNum = cleanNumber(mileage);
      
      const newImages = (req.files as Express.Multer.File[] || []).map((f) => `/uploads/${f.filename}`);
      const images = [...(JSON.parse(existingImages || "[]")), ...newImages];

      db.prepare(`
        UPDATE cars 
        SET brand = ?, model = ?, year = ?, price = ?, mileage = ?, fuel = ?, transmission = ?, status = ?, images = ?, description = ?
        WHERE id = ?
      `).run(
        brand, 
        model, 
        yearNum, 
        priceNum, 
        mileageNum, 
        fuel, 
        transmission, 
        status, 
        JSON.stringify(images), 
        description, 
        req.params.id
      );
      
      console.log("Carro atualizado com sucesso!");
      res.json({ success: true });
    } catch (error: any) {
      console.error("Erro ao atualizar carro:", error);
      res.status(500).json({ error: "Erro ao atualizar: " + error.message });
    }
  });
});

app.delete("/api/cars/:id", isAdmin, (req, res) => {
  db.prepare("DELETE FROM cars WHERE id = ?").run(req.params.id);
  res.json({ success: true });
});

app.get("/api/auth/me", (req, res) => {
  const user = (req.session as any)?.user || null;
  res.json({ user });
});

app.post("/api/auth/logout", (req, res) => {
  req.session.destroy((err) => {
    if (err) console.error("Erro ao encerrar sessão local:", err);
    res.clearCookie("feautos.sid", { 
      path: "/", 
      sameSite: process.env.NODE_ENV === "production" ? "none" : "lax",
      secure: process.env.NODE_ENV === "production",
    });
    return res.status(200).json({ success: true });
  });
});

async function startServer() {
  if (process.env.NODE_ENV !== "production") {
    const vite = await createViteServer({
      server: { middlewareMode: true },
      appType: "spa",
    });
    app.use(vite.middlewares);
  } else {
    app.use(express.static("dist"));
    app.get("*", (req, res) => {
      res.sendFile(path.resolve("dist/index.html"));
    });
  }

  app.listen(PORT, "0.0.0.0", () => {
    console.log(`Server running on http://localhost:${PORT}`);
  });
}

startServer();
