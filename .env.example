# Database URL - Set to your PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=""

# Vercel Blob Storage Token (optional) - Only needed for cloud image storage
BLOB_READ_WRITE_TOKEN=""

# Gemini AI API Key (optional)
GEMINI_API_KEY=""

# App URL - Your deployed application URL
APP_URL=""

# Google OAuth Credentials (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Session Secret - Use a strong random string in production
SESSION_SECRET="your-secret-key-change-in-production"

# Admin Credentials
ADMIN_EMAIL="admin@feautos.local"
ADMIN_PASSWORD="admin123"

# Node Environment
NODE_ENV="development"

# Server Port
PORT="3000"